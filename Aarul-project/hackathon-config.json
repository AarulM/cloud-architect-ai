{
  "project": {
    "name": "AI Solutions Architect for Hackathon",
    "version": "1.0.0",
    "description": "AWS Solutions Architect AI Assistant for Hackathon - External Root User Setup",
    "target_user": "4657-3392-1455"
  },
  "aws": {
    "region": "us-east-1",
    "profile": "hackathon-root",
    "bedrock": {
      "model_id": "us.anthropic.claude-3-5-sonnet-20241022-v2:0",
      "max_tokens": 4096,
      "required_models": [
        "anthropic.claude-3-5-sonnet-20241022-v2:0",
        "anthropic.claude-3-sonnet-20240229-v1:0",
        "anthropic.claude-3-haiku-20240307-v1:0"
      ]
    }
  },
  "application": {
    "backend": {
      "port": 3030,
      "host": "localhost",
      "mode": "direct_bedrock"
    },
    "frontend": {
      "port": 3000,
      "host": "localhost"
    }
  },
  "features": {
    "architecture_diagrams": true,
    "aws_styling": true,
    "mermaid_integration": true,
    "professional_templates": true
  },
  "setup_requirements": [
    "AWS CLI configured with root user 4657-3392-1455",
    "Amazon Bedrock model access enabled",
    "Node.js 18+ installed",
    "Python 3.8+ installed",
    "Required IAM permissions (see hackathon-iam-policy.json)"
  ]
}